# =============================================================================
# GeoNode Cluster — Arquivo de Variáveis de Ambiente
# Copie para envs/.env e edite antes de executar os playbooks.
# =============================================================================

# -----------------------------------------------------------------------------
# MODO DE DEPLOY
# vagrant   → usa Vagrantfile para criar VMs locais
# static    → usa inventário em ansible/inventories/production/hosts.yml
# -----------------------------------------------------------------------------
DEPLOY_MODE=vagrant

# -----------------------------------------------------------------------------
# REDE (Vagrant)
# Prefixo da rede privada usada pelo Vagrantfile
# -----------------------------------------------------------------------------
VAGRANT_NETWORK_PREFIX=192.168.56
VAGRANT_BOX=ubuntu/jammy64

# Recursos das VMs (Vagrant)
VM_DB_CPU=2
VM_DB_MEM=2048
VM_GEONODE_CPU=2
VM_GEONODE_MEM=4096
VM_GEOSERVER_CPU=4
VM_GEOSERVER_MEM=8192
VM_HAPROXY_CPU=1
VM_HAPROXY_MEM=512

# -----------------------------------------------------------------------------
# DOMÍNIO / ENDEREÇOS
# Em produção, substitua pelo seu domínio ou IP público
# -----------------------------------------------------------------------------
GEONODE_HOSTNAME=geonode.local
GEOSERVER_HOSTNAME=geoserver.local
HAPROXY_VIP=192.168.56.50        # IP virtual Keepalived (dev)
HAPROXY_VIP_PROD=10.0.0.50       # IP virtual Keepalived (produção)

# IPs das VMs (devem bater com o inventário de produção ou o Vagrantfile)
IP_DB=192.168.56.10
IP_GEONODE=192.168.56.20
IP_GEOSERVER_WRITE=192.168.56.30
IP_GEOSERVER_READ_1=192.168.56.31
IP_GEOSERVER_READ_2=192.168.56.32
IP_HAPROXY_1=192.168.56.40
IP_HAPROXY_2=192.168.56.41

# -----------------------------------------------------------------------------
# VERSÕES
# -----------------------------------------------------------------------------
GEONODE_VERSION=5.0.2
GEOSERVER_VERSION=2.27.4
GEOSERVER_IMAGE=geonode/geoserver:2.27.4-latest
POSTGRES_VERSION=15
POSTGIS_VERSION=3

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------
POSTGRES_USER=geonode
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=geonode
POSTGRES_DATA_DB=geonode_data
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=4MB

# -----------------------------------------------------------------------------
# GEONODE
# -----------------------------------------------------------------------------
GEONODE_SECRET_KEY=CHANGE_ME_very_long_random_secret_key_here
GEONODE_ADMIN_USER=admin
GEONODE_ADMIN_PASSWORD=CHANGE_ME_admin_password
GEONODE_ADMIN_EMAIL=admin@geonode.local

GEONODE_DB_HOST=${IP_DB}
GEONODE_DB_PORT=5432

# Django
DJANGO_SETTINGS_MODULE=geonode.settings
DEBUG=False
FORCE_REINIT=False
INVOKE_LOG_STDOUT=True
DJANGO_ALLOWED_HOSTS=*
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# Storage local ou S3
DEFAULT_BACKEND_DATASTORE=datastore
FILE_UPLOAD_MAX_MEMORY_SIZE=524288000

# Cache
CACHE_BACKEND=django.core.cache.backends.memcached.PyMemcacheCache
CACHE_LOCATION=127.0.0.1:11211

# Celery / Broker
CELERY_BROKER_URL=amqp://geonode:CHANGE_ME_rabbit@${IP_GEONODE}:5672/geonode
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# GEOSERVER
# -----------------------------------------------------------------------------
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME_geoserver_password

# Porta exposta em cada nó GeoServer
GEOSERVER_PORT=8080

# Data directory compartilhado via NFS
GEOSERVER_DATA_DIR=/opt/geoserver_data

# JVM
GEOSERVER_JAVA_OPTS=-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# NFS — servidor é o geoserver-write
NFS_SERVER=${IP_GEOSERVER_WRITE}
NFS_EXPORT_PATH=/opt/geoserver_data

# Plugins GeoServer (separados por vírgula)
# O plugin de clustering JMS é obrigatório
GEOSERVER_PLUGINS=jms-cluster,geofence-server,web-resource,monitor,control-flow

# Clustering JMS (ActiveMQ embutido)
GEOSERVER_CLUSTER_BROKER_URL=tcp://${IP_GEOSERVER_WRITE}:61666
GEOSERVER_CLUSTER_INSTANCE_NAME_WRITE=geoserver-master
GEOSERVER_CLUSTER_INSTANCE_NAME_READ_1=geoserver-worker-1
GEOSERVER_CLUSTER_INSTANCE_NAME_READ_2=geoserver-worker-2

# GeoWebCache
GWC_ENABLED=true
GWC_CACHE_DIR=/opt/geoserver_data/gwc

# -----------------------------------------------------------------------------
# HAPROXY
# -----------------------------------------------------------------------------
HAPROXY_STATS_PORT=8404
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=CHANGE_ME_haproxy_stats

# Portas frontend
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443

# SSL (deixe vazio para desabilitar HTTPS)
HAPROXY_SSL_CERT_PATH=/etc/haproxy/certs/cert.pem

# Timeouts
HAPROXY_CONNECT_TIMEOUT=10s
HAPROXY_CLIENT_TIMEOUT=60s
HAPROXY_SERVER_TIMEOUT=60s

# -----------------------------------------------------------------------------
# KEEPALIVED
# -----------------------------------------------------------------------------
KEEPALIVED_VRRP_ID=51
KEEPALIVED_VRRP_PASSWORD=CHANGE_ME_vrrp_pass
# Interface de rede usada pelo Keepalived (ajuste conforme a VM)
KEEPALIVED_INTERFACE=eth1
KEEPALIVED_MASTER_PRIORITY=101
KEEPALIVED_BACKUP_PRIORITY=100

# -----------------------------------------------------------------------------
# SSH (para Ansible em produção)
# -----------------------------------------------------------------------------
ANSIBLE_SSH_USER=ubuntu
ANSIBLE_SSH_PRIVATE_KEY=~/.ssh/id_rsa
ANSIBLE_BECOME_PASSWORD=

# -----------------------------------------------------------------------------
# MONITORAMENTO (opcional)
# -----------------------------------------------------------------------------
ENABLE_MONITORING=false
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
