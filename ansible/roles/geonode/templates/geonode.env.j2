# .env — GeoNode {{ geonode_version }}
# Gerenciado pelo Ansible

# ── Django ────────────────────────────────────────────────────
SECRET_KEY={{ geonode_secret_key }}
DEBUG={{ django_debug }}
DJANGO_SETTINGS_MODULE=geonode.settings
FORCE_REINIT=False
INVOKE_LOG_STDOUT=True
ALLOWED_HOSTS={{ django_allowed_hosts }}
TIME_ZONE={{ django_time_zone }}
LANGUAGE_CODE={{ django_language_code }}

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL=postgis://{{ postgres_user }}:{{ postgres_password }}@{{ ip_db }}:{{ postgres_port }}/{{ postgres_db }}
GEODATABASE_URL=postgis://{{ postgres_user }}:{{ postgres_password }}@{{ ip_db }}:{{ postgres_port }}/{{ postgres_data_db }}
DEFAULT_BACKEND_DATASTORE=datastore

# ── GeoServer ─────────────────────────────────────────────────
GEOSERVER_PUBLIC_HOST={{ geonode_public_hostname }}
GEOSERVER_PUBLIC_LOCATION=http://{{ geonode_public_hostname }}/geoserver/
GEOSERVER_WEB_UI_LOCATION=http://{{ geonode_public_hostname }}/geoserver/web/
GEOSERVER_LOCATION=http://{{ ip_geoserver_write }}:{{ geoserver_port }}/geoserver/
GEOSERVER_ADMIN_USER={{ geoserver_admin_user }}
GEOSERVER_ADMIN_PASSWORD={{ geoserver_admin_password }}

# ── Proxy / Site ──────────────────────────────────────────────
SITEURL=http://{{ geonode_public_hostname }}/
SITE_HOST_NAME={{ geonode_public_hostname }}
SITE_HOST_PORT=80

# ── OAuth2 ────────────────────────────────────────────────────
# Gerado na primeira execução. Armazene em envs/.env e não altere.
OAUTH2_CLIENT_ID={{ oauth2_client_id }}
OAUTH2_CLIENT_SECRET={{ oauth2_client_secret }}

# ── Storage ───────────────────────────────────────────────────
STATIC_ROOT=/mnt/volumes/statics
FILE_UPLOAD_MAX_MEMORY_SIZE=524288000
DATA_UPLOAD_MAX_MEMORY_SIZE=524288000

# ── Celery / Broker ───────────────────────────────────────────
BROKER_URL=amqp://geonode:{{ postgres_password }}@rabbitmq:5672/geonode
CELERY_RESULT_BACKEND=redis://redis:6379/0
ASYNC_SIGNALS=True

# ── Email ─────────────────────────────────────────────────────
EMAIL_ENABLE=False
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=no-reply@example.com
# EMAIL_HOST_PASSWORD=changeme

# ── Monitoramento ─────────────────────────────────────────────
USER_ANALYTICS_ENABLED=True
GEONODE_CLIENT_LAYER_PREVIEW_LIBRARY=mapstore

# ── Admin ────────────────────────────────────────────────────
ADMIN_USERNAME={{ geonode_admin_user }}
ADMIN_PASSWORD={{ geonode_admin_password }}
ADMIN_EMAIL={{ geonode_admin_email }}
