# Gerenciado pelo Ansible — incluído dentro do server block principal do Nginx.
#
# Adiciona o IP interno do GeoNode ao server_name do bloco existente.
# No Nginx, múltiplas diretivas server_name dentro do mesmo server block
# são aditivas — este arquivo soma 192.168.1.101 aos nomes já definidos
# (200.137.68.74 e 127.0.0.1), sem criar um novo bloco.
#
# Necessário para que o GeoServer consiga chamar /o/token/ e
# /api/o/v4/tokeninfo/ diretamente pela rede privada do OpenStack,
# evitando hairpin NAT (instâncias não alcançam o próprio Floating IP).
server_name {{ ip_geonode }};
