<?xml version="1.0" encoding="UTF-8"?>
<org.geoserver.security.oauth2.GeoNodeOAuthAuthenticationFilter>
  <id>geonode-oauth2</id>
  <name>geonode-oauth2</name>
  <className>org.geoserver.security.oauth2.GeoNodeOAuthAuthenticationFilter</className>
  <cliendId>{{ oauth2_client_id }}</cliendId>
  <clientSecret>{{ oauth2_client_secret }}</clientSecret>
  <accessTokenUri>http://{{ geonode_public_hostname }}/api/o/token/</accessTokenUri>
  <userAuthorizationUri>http://{{ geonode_public_hostname }}/api/o/authorize/</userAuthorizationUri>
  <redirectUri>http://{{ geonode_public_hostname }}/geoserver/web/</redirectUri>
  <checkTokenEndpointUrl>http://{{ geonode_public_hostname }}/api/o/v4/tokeninfo/</checkTokenEndpointUrl>
  <logoutUri>http://{{ geonode_public_hostname }}/api/o/revoke_token/</logoutUri>
  <scopes>read write groups</scopes>
  <enableRedirectAuthenticationEntryPoint>false</enableRedirectAuthenticationEntryPoint>
  <forceAccessTokenUriHttps>false</forceAccessTokenUriHttps>
  <forceUserAuthorizationUriHttps>false</forceUserAuthorizationUriHttps>
  <loginEndpoint>/j_spring_oauth2_geonode_login</loginEndpoint>
  <logoutEndpoint>/j_spring_oauth2_geonode_logout</logoutEndpoint>
</org.geoserver.security.oauth2.GeoNodeOAuthAuthenticationFilter>
