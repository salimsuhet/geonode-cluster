# .env — GeoServer {{ geoserver_role | upper }} ({{ inventory_hostname }})
# Gerenciado pelo Ansible

# Credenciais GeoServer
GEOSERVER_ADMIN_USER={{ geoserver_admin_user }}
GEOSERVER_ADMIN_PASSWORD={{ geoserver_admin_password }}

# Data dir (caminho dentro do container — deve coincidir com o volume no docker-compose)
GEOSERVER_DATA_DIR=/opt/geoserver/data_dir
GEOWEBCACHE_CACHE_DIR=/opt/geoserver/data_dir/gwc

# Banco de dados — nomes esperados pela imagem geonode/geoserver
DATABASE_HOST={{ ip_db }}
DATABASE_PORT={{ postgres_port }}
GEONODE_DATABASE={{ postgres_db }}
GEONODE_DATABASE_USER={{ postgres_user }}
GEONODE_DATABASE_PASSWORD={{ postgres_password }}
GEONODE_GEODATABASE={{ postgres_data_db }}
GEONODE_GEODATABASE_USER={{ postgres_user }}
GEONODE_GEODATABASE_PASSWORD={{ postgres_password }}

# Integração GeoNode — nomes esperados pela imagem geonode/geoserver
GEONODE_LB_HOST_IP={{ ip_geonode }}
GEONODE_LB_PORT=80
GEOSERVER_LB_HOST_IP={{ geonode_public_hostname }}
GEOSERVER_LB_PORT=80
NGINX_BASE_URL=http://{{ geonode_public_hostname }}
GEOSERVER_PUBLIC_LOCATION=http://{{ geonode_public_hostname }}/geoserver/
GEOSERVER_LOCATION=http://localhost:{{ geoserver_port }}/geoserver/
GEONODE_URL=http://{{ geonode_public_hostname }}

# OAuth2 — para autenticação integrada com GeoNode
# O GeoServer usa essas credenciais para configurar o filtro OAuth2
# no startup e permitir login único com o GeoNode.
OAUTH2_CLIENT_ID={{ oauth2_client_id }}
OAUTH2_CLIENT_SECRET={{ oauth2_client_secret }}

# Cluster JMS
{% if geoserver_is_master | bool %}
CLUSTER_INSTANCE_NAME={{ geoserver_cluster_instance_name_write }}
CLUSTER_IS_MASTER=true
{% else %}
CLUSTER_INSTANCE_NAME={{ geoserver_cluster_instance_name_read_1 if inventory_hostname == 'geoserver-read-1' else geoserver_cluster_instance_name_read_2 }}
CLUSTER_IS_MASTER=false
CLUSTER_MASTER_ADDRESS={{ ip_geoserver_write }}
{% endif %}
CLUSTER_BROKER_URL={{ geoserver_cluster_broker_url }}

# Performance — uma única linha (arquivos .env não suportam continuação de linha)
JAVA_OPTS={{ geoserver_java_opts }}
